{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "*.php": {
      "runtime": "vercel-php@0.9.0"
    },
    "admin/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    {
      "src": "^/$",
      "dest": "/index.php"
    },
    {
      "src": "^/admin/?$",
      "dest": "/admin/index.php"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "^/about/?$",
      "dest": "/about.php"
    },
    {
      "src": "^/contact/?$",
      "dest": "/contact.php"
    },
    {
      "src": "^/printers/?$",
      "dest": "/printers.php"
    },
    {
      "src": "^/brand/?$",
      "dest": "/brand.php"
    },
    {
      "src": "^/product/?$",
      "dest": "/product.php"
    },
    {
      "src": "^/cart/?$",
      "dest": "/cart.php"
    },
    {
      "src": "^/checkout/?$",
      "dest": "/checkout.php"
    },
    {
      "src": "^/cart-actions/?$",
      "dest": "/cart-actions.php"
    }
  ]
}
